{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "PowerShell: Launch Current File",
            "type": "PowerShell",
            "request": "launch",
            "script": "${file}",
            "args": [],
            "cwd": "${workspaceFolder}"
        },
        {
            "name": "New NFSv3 Datastore (Hourly Snapshots)",
            "type": "PowerShell",
            "request": "launch",
            "script": "${workspaceFolder}/New-NFSDatastore.ps1",
            "args": [
                "-DatastoreName", "NFSv3-Test",
                "-DatastoreSize", "10TB",
                "-NFSVersion", "nfsv3",
                "-vCenterCluster", "cluster-prod",
                "-FlashArrayEndpoint", "sn1-x90r2-f06-27.fsa.lab",
                "-vCenterServer", "vc02.fsa.lab",
                "-QuotaEnabled", "$true",
                "-SnapshotEnabled", "$true",
                "-SnapshotRulesEvery", "3600000",
                "-SnapshotRulesKeepFor", "86400000",
                "-SnapshotClientName", "hourly"
            ],
            "cwd": "${workspaceFolder}"
        },
        {
            "name": "New NFSv4 Datastore (Hourly Snapshots + Nconnect)",
            "type": "PowerShell",
            "request": "launch",
            "script": "${workspaceFolder}/New-NFSDatastore.ps1",
            "args": [
                "-DatastoreName", "NFSv4-Test",
                "-DatastoreSize", "20TB",
                "-NFSVersion", "nfsv4",
                "-vCenterCluster", "cluster-prod",
                "-NconnectSessions", "8",
                "-FlashArrayEndpoint", "sn1-x90r2-f06-27.fsa.lab",
                "-vCenterServer", "vc02.fsa.lab",
                "-QuotaEnabled", "$true",
                "-SnapshotEnabled", "$true",
                "-SnapshotRulesEvery", "3600000",
                "-SnapshotRulesKeepFor", "86400000",
                "-SnapshotClientName", "hourly"
            ],
            "cwd": "${workspaceFolder}"
        },
        {
            "name": "Remove-NFSDatastoreFromFlashArray: NFSv3-Test",
            "type": "PowerShell",
            "request": "launch",
            "script": "${workspaceFolder}/Remove-NFSDatastoreFromFlashArray.ps1",
            "args": [
                "-DatastoreName", "NFSv3-Test",
                "-FlashArrayEndpoint", "sn1-x90r2-f06-27.fsa.lab",
                "-Force"
            ],
            "cwd": "${workspaceFolder}"
        },
        {
            "name": "Remove-NFSDatastoreFromFlashArray: NFSv4-Test",
            "type": "PowerShell",
            "request": "launch",
            "script": "${workspaceFolder}/Remove-NFSDatastoreFromFlashArray.ps1",
            "args": [
                "-DatastoreName", "NFSv4-Test",
                "-FlashArrayEndpoint", "sn1-x90r2-f06-27.fsa.lab",
                "-Force"
            ],
            "cwd": "${workspaceFolder}"
        },
        {
            "name": "Mount Existing NFS: NFSv3-Test",
            "type": "PowerShell",
            "request": "launch",
            "script": "${workspaceFolder}/New-PureNFSDatastore.ps1",
            "args": [
                "-DatastoreName", "NFSv3-Test",
                "-NFSExportPath", "/NFSv3-Test",
                "-NFSHost", "filevip-f06-27.fsa.lab",
                "-vCenterCluster", "cluster-prod",
                "-vCenterServer", "vc02.fsa.lab",
                "-NFSVersion", "nfsv3"
            ],
            "cwd": "${workspaceFolder}"
        },
        {
            "name": "Mount Existing NFS: NFSv4-Test",
            "type": "PowerShell",
            "request": "launch",
            "script": "${workspaceFolder}/New-PureNFSDatastore.ps1",
            "args": [
                "-DatastoreName", "NFSv4-Test",
                "-NFSExportPath", "/NFSv4-Test",
                "-NFSHost", "filevip-f06-27.fsa.lab",
                "-vCenterCluster", "cluster-prod",
                "-vCenterServer", "vc02.fsa.lab",
                "-NFSVersion", "nfsv4",
                "-NconnectSessions", "4"
            ],
            "cwd": "${workspaceFolder}"
        },
        {
            "name": "Get NFS 4.1 Parameters",
            "type": "PowerShell",
            "request": "launch",
            "script": "${workspaceFolder}/Get-NFS41Parameters.ps1",
            "args": [
                "-vCenterServer", "vc02.fsa.lab"
            ],
            "cwd": "${workspaceFolder}"
        },
        {
            "name": "New-PureNFSFileSystem: NFSv3-Test (NFS 3)",
            "type": "PowerShell",
            "request": "launch",
            "script": "${workspaceFolder}/New-PureNFSFileSystem.ps1",
            "args": [
                "-FileSystemName", "NFSv3-Test",
                "-FileSystemSize", "100GB",
                "-NFSVersion", "nfsv3",
                "-FlashArrayEndpoint", "sn1-x90r2-f06-27.fsa.lab"
            ],
            "cwd": "${workspaceFolder}"
        },
        {
            "name": "New-PureNFSFileSystem: NFSv4-Test (NFS 4.1)",
            "type": "PowerShell",
            "request": "launch",
            "script": "${workspaceFolder}/New-PureNFSFileSystem.ps1",
            "args": [
                "-FileSystemName", "NFSv4-Test",
                "-FileSystemSize", "100GB",
                "-NFSVersion", "nfsv4",
                "-FlashArrayEndpoint", "sn1-x90r2-f06-27.fsa.lab"
            ],
            "cwd": "${workspaceFolder}"
        },
        {
            "name": "Setup-Credentials: All",
            "type": "PowerShell",
            "request": "launch",
            "script": "${workspaceFolder}/Setup-Credentials.ps1",
            "args": [],
            "cwd": "${workspaceFolder}"
        },
        {
            "name": "Setup-Credentials: FlashArray Only",
            "type": "PowerShell",
            "request": "launch",
            "script": "${workspaceFolder}/Setup-Credentials.ps1",
            "args": [
                "-FlashArrayOnly"
            ],
            "cwd": "${workspaceFolder}"
        },
        {
            "name": "Setup-Credentials: vCenter Only",
            "type": "PowerShell",
            "request": "launch",
            "script": "${workspaceFolder}/Setup-Credentials.ps1",
            "args": [
                "-vCenterOnly"
            ],
            "cwd": "${workspaceFolder}"
        },
        {
            "name": "PowerShell: Interactive Session",
            "type": "PowerShell",
            "request": "launch",
            "cwd": "${workspaceFolder}",
            "createTemporaryIntegratedConsole": false
        }
    ]
}